# ==================== 数据库 ====================
DB_HOST=localhost
DB_PORT=5432
DB_USER=travel
DB_PASSWORD=change_me
DB_NAME=travel_agent
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=20
DB_POOL_TIMEOUT=30
CHECKPOINT_RETENTION_DAYS=7
CHECKPOINT_CLEANUP_DAILY_RATE=100
CHECKPOINT_BACKEND=postgres

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==================== LLM: 千问 (DashScope) ====================
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen3-vl-flash
QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_EMBEDDING_DIMENSIONS=1024

# ==================== LLM: DeepSeek ====================
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# ==================== LLM: 小米 MiMo ====================
MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro
MIMO_MODEL_FAST=mimo-v2.5
# 系统 HTTP 代理会导致 MiMo SSL 失败；直连时保持 false
MIMO_HTTP_TRUST_ENV=false

# ==================== LangSmith 可观测性 ====================
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=travel_agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_TRACING=true

# ==================== 搜索: Tavily ====================
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=advanced
TAVILY_MAX_RESULTS=5

# ==================== 地图: 高德 ====================
AMAP_API_KEY=
AMAP_BASE_URL=https://restapi.amap.com/v3

# ==================== 航班: AviationStack ====================
AVIATIONSTACK_API_KEY=
AVIATIONSTACK_BASE_URL=https://api.aviationstack.com/v1

# ==================== 酒店: AigoHotel MCP ====================
AIGOHOTEL_API_KEY=
AIGOHOTEL_BASE_URL=https://mcp.aigohotel.com/mcp

# ==================== 天气: 和风天气 QWeather ====================
# 控制台: https://dev.qweather.com （每月前 5 万次免费）
# 1. 创建项目 → 添加凭据(API KEY) → 勾选 GeoAPI + 天气预报等权限
# 2. 在 控制台 → 设置 复制你的 API Host（形如 https://xxxx.def.qweatherapi.com）
QWEATHER_API_KEY=
QWEATHER_API_HOST=
QWEATHER_LANG=zh
QWEATHER_UNIT=m

# ==================== MCP ====================
# 天气：inprocess=adapter 直连 QWeather；stdio=经本地 FastMCP Server
MCP_WEATHER_TRANSPORT=inprocess
# MCP_PYTHON_COMMAND=  # stdio 模式可选，默认当前 Python 解释器
# 搜索：inprocess=adapter 直连 Tavily；stdio=经本地 FastMCP Server
MCP_SEARCH_TRANSPORT=inprocess
# 12306 高铁 MCP（留空则不在 Manager 中注册 train 服务）
MCP_TRAIN_URL=https://mcp.api-inference.modelscope.net/215d3cfb299e47/mcp
# 飞常准航班 MCP
VARIFLIGHT_API_KEY=

# ==================== 应用 ====================
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8200
DEBUG=true

# ==================== JWT ====================
JWT_SECRET_KEY=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
